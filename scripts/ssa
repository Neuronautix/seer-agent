#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON_BIN="$ROOT_DIR/.venv/bin/python"
STACK_SERVICE="sovereign-sensor-nanobot.service"
API_PORT=8080

WATCHDOG_STATUS_PATH="$ROOT_DIR/logs/watchdog-status.json"

LAST_DEPLOY_FILE="$ROOT_DIR/.last-deploy-commit"
BACKUP_DEFAULT_DIR="$ROOT_DIR/backups"

usage() {
  echo "Usage: ssa {install|up|down|restart|status|health|watchdog|deploy|rollback|backup|restore|rotate|check|login|tasks-login|bridge|gateway}" >&2
}

install_systemd_units() {
  echo "Installing systemd units (substituting user=$USER path=$ROOT_DIR)..."
  for unit_src in "$ROOT_DIR/deploy/systemd/"*.service "$ROOT_DIR/deploy/systemd/"*.timer; do
    [[ -f "$unit_src" ]] || continue
    unit_name="$(basename "$unit_src")"
    tmp="$(mktemp)"
    sed -e "s|/home/dhuzard/sovereign-sensor-agent|$ROOT_DIR|g" \
        -e "s|User=dhuzard|User=$USER|g" \
        "$unit_src" > "$tmp"
    sudo cp "$tmp" "/etc/systemd/system/$unit_name"
    rm -f "$tmp"
    echo "  installed /etc/systemd/system/$unit_name"
  done
}

print_started_message() {
  cat <<'EOF'
SSA stack started.
Use these commands next:
  ssa status
  ssa stop
  ssa restart

WhatsApp messages must start with:
  @ssa what is the current temperature?
  @ssa what is the threshold status?
  @ssa <admin-password> thresholds
EOF
}

COMMAND="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$COMMAND" in
  install)
    target="${1:-/usr/local/bin/ssa}"
    sudo ln -sf "$ROOT_DIR/scripts/ssa" "$target"
    sudo chmod +x "$ROOT_DIR/scripts/ssa"
    echo "Installed: $target -> $ROOT_DIR/scripts/ssa"

    install_systemd_units
    sudo systemctl daemon-reload

    # Best-effort network dependency enablement
    sudo systemctl enable NetworkManager-wait-online.service 2>/dev/null || true
    sudo systemctl enable systemd-networkd-wait-online.service 2>/dev/null || true

    # Enable ingest + api + watchdog timer at boot; nanobot stays manual
    sudo systemctl enable sovereign-sensor-ingest.service sovereign-sensor-api.service
    sudo systemctl enable sovereign-sensor-watchdog.timer

    echo ""
    echo "Enabled at boot: ingest, api, watchdog.timer"
    echo "Nanobot is NOT enabled at boot (start manually: ssa up)"
    echo "To start immediately: sudo systemctl start sovereign-sensor-ingest.service sovereign-sensor-api.service"
    ;;
  deploy|upgrade)
    echo "=== Deploying Sovereign Sensor Agent ==="

    # Save current HEAD so rollback can restore it
    git -C "$ROOT_DIR" rev-parse HEAD > "$LAST_DEPLOY_FILE"
    echo "Saved pre-deploy commit: $(cat "$LAST_DEPLOY_FILE")"

    # Auto-backup runtime data before touching anything
    echo "Creating pre-deploy backup..."
    if "$ROOT_DIR/scripts/ssa" backup "$BACKUP_DEFAULT_DIR"; then
      echo "Pre-deploy backup saved."
    else
      echo "Warning: no runtime data found to back up (continuing)."
    fi

    echo "Stopping ingest and API..."
    sudo systemctl stop sovereign-sensor-ingest.service sovereign-sensor-api.service 2>/dev/null || true

    echo "Pulling latest code..."
    git -C "$ROOT_DIR" pull

    echo "Updating Python dependencies..."
    "$PYTHON_BIN" -m pip install -q -r "$ROOT_DIR/requirements.txt"

    echo "Updating systemd units..."
    install_systemd_units
    sudo systemctl daemon-reload

    echo "Restarting ingest and API..."
    sudo systemctl start sovereign-sensor-ingest.service sovereign-sensor-api.service

    echo ""
    echo "Deploy complete. Run 'ssa health' to verify."
    echo "To rollback: ssa rollback"
    ;;
  rollback)
    if [[ ! -f "$LAST_DEPLOY_FILE" ]]; then
      echo "No pre-deploy commit found at $LAST_DEPLOY_FILE" >&2
      echo "Run 'ssa deploy' at least once before using rollback." >&2
      exit 1
    fi

    PREV_COMMIT=$(cat "$LAST_DEPLOY_FILE")
    echo "=== Rolling back to $PREV_COMMIT ==="

    echo "Stopping ingest and API..."
    sudo systemctl stop sovereign-sensor-ingest.service sovereign-sensor-api.service 2>/dev/null || true

    echo "Resetting code to pre-deploy commit..."
    git -C "$ROOT_DIR" reset --hard "$PREV_COMMIT"

    echo "Restoring Python dependencies..."
    "$PYTHON_BIN" -m pip install -q -r "$ROOT_DIR/requirements.txt"

    echo "Reloading systemd units..."
    install_systemd_units
    sudo systemctl daemon-reload

    echo "Restarting ingest and API..."
    sudo systemctl start sovereign-sensor-ingest.service sovereign-sensor-api.service

    # Remove the saved commit so a second rollback doesn't loop
    rm -f "$LAST_DEPLOY_FILE"

    echo ""
    echo "Rollback complete. Run 'ssa health' to verify."
    ;;
  backup)
    BACKUP_DIR="${1:-$BACKUP_DEFAULT_DIR}"
    mkdir -p "$BACKUP_DIR"
    TS=$(date -u +%Y%m%dT%H%M%SZ)
    BACKUP_FILE="$BACKUP_DIR/ssa-backup-$TS.tar.gz"

    ITEMS=()
    [[ -d "$ROOT_DIR/logs" ]] && ITEMS+=("logs/")
    [[ -f "$ROOT_DIR/threshold-config.json" ]] && ITEMS+=("threshold-config.json")
    [[ -d "$ROOT_DIR/deploy/nanobot/auth_info_multidevice" ]] && ITEMS+=("deploy/nanobot/auth_info_multidevice/")

    if [[ ${#ITEMS[@]} -eq 0 ]]; then
      echo "Nothing to back up (no logs or runtime state found)." >&2
      exit 1
    fi

    tar -czf "$BACKUP_FILE" -C "$ROOT_DIR" "${ITEMS[@]}"
    echo "Backup saved: $BACKUP_FILE"
    echo "Contents: ${ITEMS[*]}"
    ;;
  restore)
    BACKUP_FILE="${1:-}"
    if [[ -z "$BACKUP_FILE" ]] || [[ ! -f "$BACKUP_FILE" ]]; then
      echo "Usage: ssa restore <backup-file.tar.gz>" >&2
      exit 1
    fi

    echo "=== Restoring from $BACKUP_FILE ==="

    echo "Stopping ingest and API..."
    sudo systemctl stop sovereign-sensor-ingest.service sovereign-sensor-api.service 2>/dev/null || true

    echo "Extracting backup..."
    tar -xzf "$BACKUP_FILE" -C "$ROOT_DIR"

    echo "Restarting ingest and API..."
    sudo systemctl start sovereign-sensor-ingest.service sovereign-sensor-api.service

    echo ""
    echo "Restore complete. Run 'ssa health' to verify."
    ;;
  up|start)
    sudo systemctl start "$STACK_SERVICE"
    print_started_message
    ;;
  down|stop)
    exec sudo systemctl stop "$STACK_SERVICE"
    ;;
  restart)
    exec sudo systemctl restart "$STACK_SERVICE"
    ;;
  status)
    exec sudo systemctl --no-pager --full status sovereign-sensor-ingest.service sovereign-sensor-api.service "$STACK_SERVICE"
    ;;
  health)
    echo "=== Sovereign Sensor Agent Health ==="
    echo ""

    # systemd service states
    printf "  %-46s %s\n" "SERVICE" "STATE"
    printf "  %-46s %s\n" "-------" "-----"
    for svc in sovereign-sensor-ingest.service sovereign-sensor-api.service "$STACK_SERVICE"; do
      state=$(systemctl is-active "$svc" 2>/dev/null || true)
      printf "  %-46s %s\n" "$svc" "${state:-unknown}"
    done
    echo ""

    # API freshness via /health endpoint
    health_json=$(
      "$PYTHON_BIN" -c '
import json, sys, urllib.request
port = int(sys.argv[1])
try:
    with urllib.request.urlopen("http://127.0.0.1:%d/health" % port, timeout=2) as r:
        sys.stdout.write(r.read().decode())
except Exception as e:
    sys.stdout.write(json.dumps({"ok": False, "error": str(e)}))
' "$API_PORT" 2>/dev/null || echo '{"ok":false,"error":"API unreachable"}'
    )
    if "$PYTHON_BIN" -c "import json,sys; d=json.loads(sys.stdin.read()); sys.exit(0 if d.get('ok') else 1)" <<< "$health_json" 2>/dev/null; then
      status_val=$("$PYTHON_BIN" -c "import json,sys; d=json.loads(sys.stdin.read()); print(d.get('status','unknown'))" <<< "$health_json" 2>/dev/null || echo "unknown")
      observed_at=$("$PYTHON_BIN" -c "import json,sys; d=json.loads(sys.stdin.read()); print(d.get('lastObservationAt','n/a'))" <<< "$health_json" 2>/dev/null || echo "n/a")
      age=$("$PYTHON_BIN" -c "import json,sys; d=json.loads(sys.stdin.read()); print(d.get('freshnessAgeSeconds','n/a'))" <<< "$health_json" 2>/dev/null || echo "n/a")
      printf "  API status:            %s\n" "$status_val"
      printf "  Last observation at:   %s\n" "$observed_at"
      printf "  Data age (seconds):    %s\n" "$age"
    else
      err=$("$PYTHON_BIN" -c "import json,sys; d=json.loads(sys.stdin.read()); print(d.get('error','unknown error'))" <<< "$health_json" 2>/dev/null || echo "unknown error")
      printf "  API status:            unreachable (%s)\n" "$err"
    fi
    echo ""

    # Watchdog status from last timer run
    printf "  WATCHDOG\n"
    if [[ -f "$WATCHDOG_STATUS_PATH" ]]; then
      wd_status=$("$PYTHON_BIN" -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('status','unknown'))" "$WATCHDOG_STATUS_PATH" 2>/dev/null || echo "unreadable")
      wd_checked=$("$PYTHON_BIN" -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('checkedAt','n/a'))" "$WATCHDOG_STATUS_PATH" 2>/dev/null || echo "n/a")
      printf "  Last watchdog run:     %s\n" "$wd_checked"
      printf "  Watchdog result:       %s\n" "$wd_status"
    else
      printf "  Watchdog status:       no status file yet (run: ssa watchdog)\n"
    fi
    echo ""
    ;;
  watchdog)
    exec "$PYTHON_BIN" "$ROOT_DIR/scripts/watchdog.py" "$@"
    ;;
  rotate)
    exec "$PYTHON_BIN" "$ROOT_DIR/scripts/rotate_logs.py" "$@"
    ;;
  check)
    exec "$PYTHON_BIN" "$ROOT_DIR/scripts/check_env.py" "$@"
    ;;
  login|link)
    exec "$ROOT_DIR/deploy/nanobot/start_nanobot.sh" whatsapp-login "$@"
    ;;
  tasks-login|gtasks-login)
    exec "$ROOT_DIR/deploy/nanobot/start_nanobot.sh" gtasks-login "$@"
    ;;
  bridge)
    exec "$ROOT_DIR/deploy/nanobot/start_nanobot.sh" whatsapp-bridge "$@"
    ;;
  gateway)
    exec "$ROOT_DIR/deploy/nanobot/start_nanobot.sh" gateway "$@"
    ;;
  *)
    usage
    exit 2
    ;;
esac
