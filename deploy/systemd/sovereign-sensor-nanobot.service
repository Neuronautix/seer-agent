[Unit]
Description=Sovereign Sensor Agent WhatsApp Stack
Wants=network-online.target
After=network-online.target sovereign-sensor-api.service
Requires=sovereign-sensor-api.service

[Service]
Type=simple
User=ssa
WorkingDirectory=/opt/sovereign-sensor-agent
Environment=PYTHONUNBUFFERED=1
ExecStartPre=/opt/sovereign-sensor-agent/.venv/bin/python /opt/sovereign-sensor-agent/scripts/check_env.py --service nanobot
ExecStart=/opt/sovereign-sensor-agent/deploy/nanobot/start_nanobot.sh up
Restart=on-failure
RestartSec=5
TimeoutStopSec=15
StandardOutput=journal
StandardError=journal
# Security: Nanobot is network-facing; must never touch serial devices
NoNewPrivileges=true
PrivateDevices=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target